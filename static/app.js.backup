function renderMessagePanel() {
  const lead = state.selectedLead;
  $("#messageEmpty").classList.toggle("hidden", Boolean(lead));
  $("#messagePanel").classList.toggle("hidden", !lead);
  if (!lead) return;
  $("#messageLeadName").textContent = lead.company_name;
